VITE_API_BASE_URL=/api/v1

# Backend target for the Vite dev server proxy (see vite.config.ts).
# Not read by the browser bundle — dev-server only.
VITE_API_PROXY_TARGET=http://localhost:8000

# NOTE: The login endpoint uses OAuth2PasswordRequestForm (form-urlencoded),
# not JSON. The field is called "username" but accepts an email.
